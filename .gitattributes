# 统一换行符：源码与文本统一 LF（跨平台一致），Windows 本地 checkout 时不变。
* text=auto eol=lf

# 二进制资源，不做换行符转换
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.glb binary
*.bin binary
*.ktx2 binary
*.mp3 binary
*.aac binary
*.jar binary
*.pdf binary
*.so binary

# 脚本保持 LF
*.sh text eol=lf
gradlew text eol=lf
gradlew.bat text eol=crlf
